# ── App ──
APP_ENV=development
APP_MODE=sandbox  # sandbox | live

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=DEBUG

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Database ──
DATABASE_URL=sqlite:///./data/wudao.db

# ── Exchange (ccxt) ──
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_SANDBOX=true

# ── Encryption ──
FERNET_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notion ──
NOTION_API_TOKEN=
NOTION_DATABASE_ID=

# ── Webhook ──
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_DEFAULT_ACCOUNT_ID=
